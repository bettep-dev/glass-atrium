# =============================================================================
# Atrium Monitor .env template — environment-agnostic placeholders only
# (userless socket URLs + a literal HOME token). `scripts/oss-db-setup.sh`
# renders all 4 keys; manual use: `cp .env.example .env` and fill by hand.
# Never commit .env (gitignored).
# =============================================================================

# PostgreSQL Unix-socket connection (peer auth — no password, no TCP host).
# Rendered form: postgresql://<your-os-user>@localhost/glass_atrium?host=/tmp
# The user segment MUST be present in the final URL: with an empty user,
# Prisma's schema engine connects as a built-in default user instead of the
# OS peer user and `migrate deploy` fails with P1010.
DATABASE_URL=postgresql:///glass_atrium?host=/tmp

# Shadow DB — required only for `prisma migrate dev`: a drift-detection safety
# net, without which the raw-SQL tsvector GENERATED columns + GIN/trgm indexes
# (wiki.notes / monitor.documents) are misread as drift every migration cycle.
# Separate DB on the same PG instance; oss-db-setup.sh creates it idempotently.
# One-time manual equivalent:
#   psql -h /tmp -d postgres -c 'CREATE DATABASE glass_atrium_shadow OWNER <your-os-user>;'
SHADOW_DATABASE_URL=postgresql:///glass_atrium_shadow?host=/tmp

# Monitor web port — render output of config.toml [ports].monitor
# (scripts/render-monitor-env.sh upserts it; 16145 = stock default).
ATRIUM_MONITOR_PORT=16145

# clauded-docs HTML primary root — render output of config.toml
# [paths].monitor_docs_html_root. dotenv does NOT expand the HOME token below:
# it is expanded at render time (oss-db-setup.sh), and
# scripts/render-monitor-env.sh re-syncs the value from config.toml.
CLAUDED_DOCS_HTML_ROOT=${HOME}/.glass-atrium/monitor/data/documents
