/// daily-restart 데몬이 05:00 KST wiki 세션 context reset 담당.
/// daemon_runs PK (run_date, daemon_name) 공유로 autoagent/wiki 양 역할 행이 같은
/// 'daily-restart' 이름으로 상호 덮어씀 → 역할 한정 2종으로 식별 분리 (구 값은 과거 행 전용).
enum DaemonType {
  autoagent
  wiki
  daily_restart           @map("daily-restart")
  daily_restart_autoagent @map("daily-restart-autoagent")
  daily_restart_wiki      @map("daily-restart-wiki")

  @@schema("core")
}

enum DaemonStatus {
  ok
  partial
  error
  missing
  stale
  /// Claude Max quota 소진으로 daemon prompt 호출 실패 — user-domain 이므로 alert 억제 대상
  quota_exceeded

  @@schema("core")
}

enum CostGuardState {
  ok
  warn
  block
  /// 401/credential 인증 실패 등 인프라 결함 — usage/spend 가 아닌 fault 신호이므로
  /// 'warn'(사용량 알림)과 분리 (오분류 차단: auth 실패를 'Spending guard'로 표시 금지).
  infra_fault

  @@schema("core")
}

/// Canonical 9-type contract — SoT = rules/core-outcome-record.md "task_type set".
/// Additive expand (5→9): 4 non-code types added (review/diagnosis/doc/cleanup).
/// All 4 new values are plain identifiers (no hyphen) → no @map needed (only the
