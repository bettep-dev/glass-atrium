  needs_context
  fail

  @@schema("core")
}

enum Confidence {
  high
  medium
  low

  @@schema("core")
}

enum LearningStatus {
  identified
  proposed
  approved
  applied
  rejected

  @@schema("core")
}

enum ApprovalTier {
