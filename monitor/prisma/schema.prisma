/// 책임 단위:
///   - 메타 = DB · 본문 = FS (ADR-1 하이브리드) — html_path 만 저장 · body blob 없음
///   - HTML SoT (ADR-3) — content_hash 는 SHA256(HTML 본문) · last_synced_at = 사본 재생성 시각
///   - 검색 인덱스 = tsvector(GIN) + pg_trgm(wiki.gin_trgm_ops 재사용 · monitor 스키마 한정 인덱스)
///   - indexable_text = 앱 레이어가 HTML→plaintext 추출 후 채움 (Postgres GENERATED 불가 — 변환은 app 책임)
///
/// Note: tsvector `ts` 칼럼 + GIN 인덱스(`monitor_documents_ts_gin`,
/// `monitor_documents_*_trgm`) 는 raw SQL appendix 로 추가됨
/// (wiki.notes 와 동일 패턴 — Prisma DSL 은 GENERATED tsvector + gin_trgm_ops 를 표현 못 함).
model ClaudedDoc {
  id            BigInt    @id @default(autoincrement())
  // 폐기된 prefix 분류의 잔존 데이터 — 앱이 더 이상 읽거나 쓰지 않음 (기존 행 backfill 보존 · 신규 행 NULL)
  legacyPrefix  String?   @map("legacy_prefix")
  title         String
  author        String    @db.VarChar(64)
  createdAt     DateTime  @map("created_at") @db.Timestamptz(6)
  // Wave 3-2a follow-up (CID 2026-05-22T1135_doc-mgmt-enhance_a1b2) —
  //   doc_type 컬럼 DROP (선행 migration) + DocType enum DROP (본 sub-cycle)
  //   server route 의 60+ doc_type / DocTypeLiteral reference 전량 제거 후 enum 안전 DROP
  // SHA256(HTML 본문) — ADR-3 SoT 무결성 검증 키 · 64자 hex
  contentHash   String    @map("content_hash") @db.VarChar(64)
  // ADR-1 하이브리드 — monitor/data/documents/{id}.html 형식 절대 경로
  htmlPath      String    @map("html_path")
  // 폐기된 사본 경로의 잔존 컬럼 — 항상 NULL · 계약 호환성 위해 보존 (앱이 더 이상 읽거나 쓰지 않음)
  mdCopyPath    String?   @map("md_copy_path")
  // ADR-2 검색 인덱스 원천 — title + HTML 태그 제거 plaintext (앱 레이어 채움)
  indexableText String    @map("indexable_text")
  // ADR-3 사본 정합성 — html_path 기준 마지막 사본 생성 시각 · 사본 없으면 NULL
  lastSyncedAt  DateTime? @map("last_synced_at") @db.Timestamptz(6)
  // 노출 비트 — 'exposed'/'hidden' 으로 목록·검색 노출 여부만 결정 · NULL = 미지정(read 시 exposed fallback)
  //   - 레거시 값(public·ops → exposed · agent-only → hidden)은 backfill 없이 read-time 정규화
  audience      String?   @db.VarChar(16)
  // 행 입력 시각 — created_at 과 분리(에이전트 작성일 ≠ DB 적재일 가능성)
  insertedAt    DateTime  @default(now()) @map("inserted_at") @db.Timestamptz(6)
  // Phase 1b (plan doc#1789 rev2 ADR-4 R1): 본 문서가 대체(supersede)한 이전 버전 ID.
  //   - NULL = chain root (전임자 없음 — 신규 작성본 또는 최초 버전)
  //   - 값 존재 = 본 행이 supersedes_id 가 가리키는 행의 후속 버전 (Phase 2 에서 채택 시점 transition)
  //   - Wave 3-2a follow-up — DocType.superseded enum 폐지 후 transition target = doc_status='done'
  supersedesId  BigInt?   @map("supersedes_id")
  // Phase A (CID 2026-05-22T1135_doc-mgmt-enhance_a1b2 · 사용자 directive 4) — 2-value workflow gate.
  //   - DocStatus enum (progress | done) · NOT NULL DEFAULT progress
  //   - draft → progress · final/archived/superseded → done (migration backfill)
  //   - Phase B handleUpdate: same folder_id 행 cascade (app-layer single-statement CTE — DB trigger 미채택)
  docStatus     DocStatus @default(progress) @map("doc_status")
  // Phase A (사용자 directive 1·3·4) — 그룹 식별자 (NULL = ungrouped).
  //   - 같은 folder_id 값 보유 행 = 같은 그룹 · 대제목 = 그룹 내 MAX(created_at) 행의 title
  //   - 50 group/page pagination (CTE/window function — Part 2 §1 채택 D-pattern UNION ALL)
  //   - 자기참조 FK (group root 행의 id 를 가리키는 패턴 — 별도 group 테이블 미생성, surface area 최소)
  //   - onDelete: SetNull (group root 삭제 시 그룹 단절 · NOT CASCADE — silent 그룹 전체 삭제 위험 차단)
  folderId      BigInt?   @map("folder_id")
  // Group display order (CID 2026-06-01T1145_group-order-db_b1a2) — 그룹 내 명시적 정렬 순서.
  //   - NULLABLE: NULL = 미설정 (callers fall back to created_at 정렬) · 값 = 0-based 그룹 내 순서
  //   - ungrouped 행(folder_id IS NULL)은 항상 NULL — 단일 멤버 그룹은 순서 개념 무의미
  //   - drag-and-drop reorder UI/API 가 후속 cycle 에서 본 컬럼에 explicit 값 기록 (본 cycle = DB layer only)
  //   - backfill: 기존 그룹 행을 folder_id 별 created_at ASC 0-based 채움 (현재 시각 순서 보존)
  displayOrder  Int?      @map("display_order")

  // 자기참조 양방향 named relation — "DocRevisionChain" (전임/후임 관계 단일 의미축)
  //   - predecessor: 본 행이 대체한 이전 버전 (0..1 — supersedes_id 가 가리키는 행)
  //   - successors: 본 행을 대체하는 후속 버전 목록 (0..N — 본 행의 id 를 supersedes_id 로 갖는 행들)
  //   - onDelete: SetNull (전임 삭제 시 chain 단절 · NOT CASCADE — silent 다중 삭제 위험 차단)
  //   - onUpdate: Cascade (BigInt PK 변경은 통상 발생하지 않으나 안전망)
  predecessor   ClaudedDoc?  @relation("DocRevisionChain", fields: [supersedesId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  successors    ClaudedDoc[] @relation("DocRevisionChain")
  // Phase A — folder 자기참조 양방향 named relation ("DocFolderGroup")
  //   - folderParent: 본 행이 속한 그룹의 root (0..1 — folder_id 가 가리키는 행)
  //   - folderMembers: 본 행을 root 로 가리키는 멤버 행들 (0..N — 본 행의 id 를 folder_id 로 갖는 행들)
  //   - 의미축 분리: DocRevisionChain 은 lifecycle 직렬 · DocFolderGroup 은 동일 작업 묶음 병렬
  folderParent  ClaudedDoc?  @relation("DocFolderGroup", fields: [folderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  folderMembers ClaudedDoc[] @relation("DocFolderGroup")

  // 단일 콘텐츠 1행 — 동일 SHA256 본문 중복 적재 차단 (멱등성)
  @@unique([contentHash], map: "monitor_documents_hash_uniq")
  // 목록 화면 작성일 역순 정렬 — 폐기된 (prefix, created_at) 복합 인덱스의 정렬 기능 대체
  @@index([createdAt(sort: Desc)], map: "monitor_documents_created_idx")
  // 작성자 facet
  @@index([author, createdAt(sort: Desc)], map: "monitor_documents_author_created_idx")
  // Wave 3C — monitor_documents_type_created_idx DROP (docType 컬럼 제거 의존 cascade)
  // Phase 1b partial index — revision chain 조회 (NULL 다수 → partial 로 storage + write cost 절감,
  // outcomes_style_ref_agent_ts_idx 선례 동일 패턴).
  // Note: Prisma DSL 은 WHERE 절 partial index 미지원 → migration SQL 에서만 정의
  // (plain @@index 선언 시 migrate diff 가 partial predicate 를 drop 하고 full index 로 재생성).
  // Phase A partial indexes (migration 20260522165155):
  //   - monitor_documents_folder_id_idx ON (folder_id) WHERE folder_id IS NOT NULL
  //     → Phase B handleUpdate cascade WHERE folder_id = $1 (EXPLAIN: Index Scan, 0.146 ms)
  //   - monitor_documents_folder_created_idx ON (folder_id, created_at DESC, id DESC)
  //     WHERE folder_id IS NOT NULL
  //     → Phase B handleList group-page (Part 2 §1 D-pattern split-path UNION ALL · 1.912 ms @5000 rows)
  //   - 두 인덱스 동일 partial predicate · 첫 번째는 cascade UPDATE 의 lightweight lookup, 두 번째는
  //     list query 의 sort-aware covering — 분리 정당 (composite 단독으로 leading column equality 가능
  //     하나 Postgres planner 가 cascade UPDATE 의 단순 lookup 에는 단일 컬럼 index 우선 선택).
  // group-order partial index (migration 20260601114500 · CID 2026-06-01T1145_group-order-db_b1a2):
  //   - monitor_documents_folder_order_idx ON (folder_id, display_order) WHERE folder_id IS NOT NULL
  //     → 후속 reorder API 의 group-member explicit-order 조회 (ORDER BY folder_id, display_order)
  //   - 동일 partial predicate (folder_id IS NOT NULL) — 위 두 인덱스와 동일 convention
  //   - Prisma DSL WHERE-절 partial 미지원 → @@index 미선언 · migration SQL 에서만 정의 (위 Note 동일).
  @@map("documents")
  @@schema("monitor")
}

/// Source: monitor settings screen "Models & budgets" (per model-config spec doc 36166 D1 — key-value store)
/// 1행 = 도메인별 모델 지정('model.*') 또는 daemon per-call hard-cap budget('budget.*').
///   - DB = UI SoT — daemon-config.json 은 PUT write-through 로 렌더되는 소비자 뷰 (D2)
///   - budget.* 값은 trailing-zero 보존 문자열 ('0.50' ≠ 0.5 — daemon-config.json loader 계약 ·
///     daemon_cycle 이 `claude -p --max-budget-usd <value>` 로 verbatim 전달)
///   - 'inherit' = 해당 surface 에 명시 모델 없음 (frontmatter model 라인 / REPL 키 부재·제거)
///   - settings.json 쓰기 경로 없음 — orchestrator 도메인 = display-only (D5 harness-path 보호)
model ModelConfig {
  configKey   String   @id @map("config_key") @db.VarChar(64)
  configValue String   @map("config_value")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedBy   String   @map("updated_by") @db.VarChar(64)

  @@map("model_config")
  @@schema("monitor")
}

// ============================================================================
// Wave 2 — Telemetry baseline (계획: clauded-docs/370 v2 후보 F)
//   F = SkillActivation — agent activation 분포 측정 (Wave m9z3 cleanup 이전 skill+agent
//       통합이었으나, Claude Code framework 가 Skill activation event 미지원 확인 →
//       skill_name 컬럼·인덱스 drop · agent activation 단일 sink 로 좁힘. 1703 row 중
//       skill_name nonempty 단 1건 (smoke-test) — 회귀 영향 없음).
//   적재 빈도 가정 ≈ 100+ rows/hour → BigInt id · 시간축 + 이름축 + 필터축 index 의무.
// ============================================================================

/// Source: orchestrator/subagent agent activation telemetry (plan clauded-docs/370 v2 후보 F)
/// selected=false 행은 후보 제시 후 미선택 케이스 (false-positive activation 측정 신호).
/// match_score 는 0.000–1.000 정밀도.
/// 테이블명 `skill_activations` 는 Wave 2 origin 유지 (rename = R2 별도 cycle 결정 후보).
model SkillActivation {
  id            BigInt   @id @default(autoincrement())
  occurredAt    DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)
  /// 'orchestrator' | 'subagent' | 'hook' | 'manual' — free-form (enum 화는 사용 패턴 누적 후 검토)
  source        String   @db.VarChar(32)
  /// 활성화된 agent (e.g., 'reporter') — Wave m9z3 cleanup 이후 NOT NULL 의도 (route 가 강제)
  agentName     String?  @map("agent_name") @db.VarChar(64)
  /// 매칭된 트리거 문구 또는 task description 요약 (≤ 500자 권장)
  triggerPhrase String?  @map("trigger_phrase")
  /// true = 실제 사용 · false = 후보 제시 후 미선택 (false-positive 신호)
  selected      Boolean
  /// 0.000 – 1.000 confidence · optional (소스가 score 미제공 시 NULL)
  matchScore    Decimal? @map("match_score") @db.Decimal(4, 3)
  /// 위임 추적 ID (orchestrator-role.md CID 포맷 — YYYY-MM-DDTHHMM_slug_xxxx)
  cid           String?  @db.VarChar(96)
  /// 자유 형식 (e.g., user intent summary, fallback reason)
  metadata      Json?    @db.JsonB

  @@index([occurredAt], map: "skill_activations_ts_idx")
  @@index([agentName, occurredAt], map: "skill_activations_agent_ts_idx")
  @@index([selected, occurredAt], map: "skill_activations_selected_ts_idx")
  @@map("skill_activations")
  @@schema("core")
}
