enum TaskType {
  bug_fix  @map("bug-fix")
  feature
  refactor
  research
  plan
  review
  diagnosis
  doc
  cleanup

  @@schema("core")
}

/// Deterministic 3-state grader signal (track-outcome.sh) — SEPARATE column from
