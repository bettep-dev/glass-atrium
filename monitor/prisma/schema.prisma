// SoT for the monitor web app's typed PG client.
// Hooks (bash/python) bypass Prisma and write to PG directly.
// Connection: Unix socket only via DATABASE_URL host=/tmp.

// `output` REQUIRED on prisma-client provider — client emits to ../src/generated/prisma.
// `postgresqlExtensions` is validator-enforced Preview in 7.8.0.
generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

// No `url` here — CLI reads it from prisma.config.ts; runtime uses @prisma/adapter-pg via process.env.
datasource db {
  provider   = "postgresql"
  schemas    = ["core", "wiki", "monitor"]
  extensions = [pg_trgm(schema: "wiki"), btree_gin(schema: "wiki")]
}

