/// Source: cost-tracker.sh Stop hook (per plan §3.2 cost_events)
/// Token-collection-completeness fix (CID 2026-06-05T1734_token-collect_b2c3):
///   - kind ('turn'|'subagent') — row provenance discriminator. 'turn' = a main
///     per-turn aggregate (carries stop_reason/num_turns/model — turn-stats SoT);
///     'subagent' = one Task/workflow agent file's token total (MUST be excluded
///     from turn-stats so it does not pollute stop_reason distribution / num_turns).
///   - dedupKey — STABLE per-row identifier replacing the old time-based
///     (session_id, event_date, event_time) dedup. A re-scan of the same turn or
///     subagent UPSERTs the SAME row instead of inserting a duplicate, so the
///     Stop multi-fire / full-file re-aggregation no longer double-counts (RC2).
///       * kind='turn'     → dedupKey = turn-boundary real-user message uuid
///                           (1 user-uuid = exactly 1 turn; validated unique on
///                            the sample session — 125 uuids, 125 distinct).
///       * kind='subagent' → dedupKey = agent file id from agent-<id>.jsonl
///                           (validated unique — 162 files, 162 distinct ids).
model CostEvent {
  id                  BigInt   @id @default(autoincrement())
  eventDate           DateTime @map("event_date") @db.Date
  eventTime           DateTime @map("event_time") @db.Time(6)
  sessionId           String   @map("session_id")
  // Row provenance — see model doc. NOT NULL DEFAULT 'turn': every legacy row is
  // a main per-turn row, so 'turn' is the semantically-correct backfill value and
  // keeps the existing turn-stats/by-model reads unchanged for historical data.
  kind                String   @default("turn") @db.VarChar(16)
  // Stable dedup identifier — see model doc. NULLABLE so the backfill can
  // populate it idempotently for legacy rows (legacy rows lacking a derivable
  // turn-uuid get a deterministic synthetic key; see migration). New writes from
  // the upgraded hook + backfill ALWAYS supply a non-NULL dedupKey.
  dedupKey            String?  @map("dedup_key")
  inputTokens         BigInt   @map("input_tokens")
  outputTokens        BigInt   @map("output_tokens")
  cacheReadTokens     BigInt   @map("cache_read_tokens")
  cacheCreationTokens BigInt   @map("cache_creation_tokens")
  costUsd             Decimal  @map("cost_usd") @db.Decimal(12, 6)
  durationMs          BigInt   @map("duration_ms")
  numTurns            Int      @map("num_turns")
  stopReason          String?  @map("stop_reason") @db.VarChar(64)
  model               String?  @db.VarChar(128)
  parseError          Boolean  @map("parse_error")
  rawInput            String?  @map("raw_input") @db.VarChar(500)
  insertedAt          DateTime @default(now()) @map("inserted_at") @db.Timestamptz(6)

  // Stable-key dedup — replaces the old time-based cost_events_dedup. ON CONFLICT
  // target for the hook + backfill UPSERT. (session_id, dedup_key) is the conflict
  // arbiter: re-scanning a turn/subagent UPDATEs the matching row in place.
  @@unique([sessionId, dedupKey], map: "cost_events_session_dedup_key")
  @@index([eventDate, eventTime], map: "cost_events_date_time_idx")
  @@index([sessionId], map: "cost_events_session_idx")
  @@index([model], map: "cost_events_model_idx")
  // Turn-stats / by-model reads filter kind='turn'; partial index keeps those
  // scans off subagent rows (declared in migration SQL — Prisma 7 cannot express
  // WHERE predicates; plain @@index would drop the partial predicate on diff).
  @@map("cost_events")
  @@schema("core")
}

/// Source: agent-tracker.sh SubagentStart/Stop hook (per plan §3.2 agent_events)
model AgentEvent {
  id        BigInt   @id @default(autoincrement())
  eventTs   DateTime @map("event_ts") @db.Timestamptz(6)
  eventName String   @map("event_name") @db.VarChar(64)
  agentId   String   @map("agent_id")
  agentType String   @map("agent_type") @db.VarChar(64)

  @@unique([eventTs, agentId, eventName], map: "agent_events_dedup")
  @@index([eventTs], map: "agent_events_ts_idx")
  @@index([agentType, eventTs], map: "agent_events_type_ts_idx")
  @@map("agent_events")
  @@schema("core")
}

/// Source: outcome-record.sh frontmatter (per plan §3.2 outcomes — all flat columns,
/// concerns as TEXT[] per revision 2 normalization)
model Outcome {
  id                BigInt        @id @default(autoincrement())
  recordTs          DateTime      @map("record_ts") @db.Timestamptz(6)
  agent             String        @db.VarChar(64)
  taskType          TaskType      @map("task_type")
  result            OutcomeResult
  confidence        Confidence?
  metricPass        Boolean?      @map("metric_pass")
  metricType        String?       @map("metric_type") @db.VarChar(32)
  revisionCount     Int           @default(0) @map("revision_count")
  evaluativeSignal  Int?          @map("evaluative_signal")
  directiveHint     String?       @map("directive_hint")
  lesson            String?
  concerns          String[]      @default([]) @db.Text
  // qa_score — QA-review telemetry (glass-atrium-qa-code-reviewer / -debugger).
  // Scalar text of shape cov=N,ins=N,instr=N,clar=N (each 1-5); NULL on every
  // non-QA outcome. Writer self-emitted Model-Based signal, never a grader verdict.
  qaScore           String?       @map("qa_score")
  filesModified     String[]      @default([]) @map("files_modified") @db.Text
  correlationId     String?       @map("correlation_id") @db.VarChar(96)
  cid               String?       @db.VarChar(96)
  // Wave 15 fix: outcome-record.sh:373-417 computes attribution provenance
  // (agent-id-missing / cron-derived / completion-missing / etc.) — persistence
  // wire-up was missing → learning-aggregator.py:374-389 always saw empty string.
  // Wave 2026-05-14 (plan doc 1012 P2) → 2026-05-29 (e5f3) — CHECK constraint NOT VALID, 9종 캐노니컬:
  //   - hook-input             : default — happy path
  //   - cron-derived           : autoagent-cron / wiki-daily-compile 등 5개 cron
  //   - agent-id-missing       : Python label-clarification 분기
  //   - subagent-stop-missing  : R1 인스트루멘테이션 라벨
  //   - completion-missing     : [COMPLETION] block 부재 감지 (관측 라벨)
  //   - conversation-only      : Tier-3 fallback — turn 0 tool_use (95.1% 노이즈 식별)
  //   - truncated_completion   : Tier-2 fallback — open tag + close tag 부재 (실 truncation)
  //   - completion-synthesized : block 부재 → outcome-record.sh 결정론 합성 record (복구 산출물 · 2026-05-29 추가)
  //   - budget-truncation      : subagent 예산 초과 truncation 라벨 (dual-write source · 9번째 값)
  //   - structuredoutput-derived   : schema-mode terminal StructuredOutput, [COMPLETION] 부재 → 합성 done/low (10번째 값)
  //   - structuredoutput-completion: SO input completion_block 필드에서 복구한 writer [COMPLETION] block (writer-emitted · 11번째 값)
  // String? 유지 (Prisma enum 미도입). CHECK 는 migration 이 아닌 oss-db-setup.sh post-deploy
  // raw-SQL 로 DB-side 적용 (applied baseline SQL 수정 시 checksum drift → 회피). Nullable:
  // historical rows pre-2026-05-09 legitimately have NULL (NOT VALID 가 면제).
  attributionSource String?       @map("attribution_source")
  summary           String
  reviewFlag        Boolean       @default(false) @map("review_flag")
  bodyMd            String?       @map("body_md")
  // Cycle 3.3.a (2026-05-20): plan AC-B4 backing data — DEV-agent Project Convention
  // Probe telemetry. Path-or-'greenfield' literal emitted by outcome-record.sh L1098/
  // L1114 (Cycle 3.2). NULL = pre-Cycle-3.2 row OR v1.0 OPTIONAL silent omit. v1.1
  // MANDATORY graduation (per plan ADR-2) requires emission ≥ 50% AND fake_rate < 10%.
  styleRef          String?       @map("style_ref")
  // Set by track-outcome.sh _compute_style_ref_verified at SubagentStop (shared matcher
  // lib/style_ref_match.py). TRUE = path matched session Read history; FALSE =
  // Gaming-the-Judge candidate (R2-06); NULL = style_ref is 'greenfield'/NULL itself
  // (verify structurally N/A) OR a pre-verify row. hooks/style-ref-verify.sh is RETIRED
  // (do NOT wire) — a standalone Stop/SubagentStop variant sharing that same matcher,
  // superseded by this persisted column.
  styleRefVerified  Boolean?      @map("style_ref_verified")
  // Phase 1 P1.3.2 (2026-05-24): 3-Tier Eval Grader rollout marker (plan doc 1779).
  // TRUE = row predates 3-Tier wire-in AND metric_pass=NULL (legacy EMPTY backfill,
  // 1223 author-side rows · agent NOT IN orchestrator/subagent_stop_missing/unknown).
  // NULL = post-wire-in row OR infra-attribution agent (out-of-scope per ADR-4 / AC-3).
  // Partial index outcomes_baseline_pre_3tier_idx WHERE baseline_pre_3tier IS NOT NULL
  // (migration raw SQL only — Prisma 7 schema cannot declare partial-index predicates).
  baselinePre3tier  Boolean?      @map("baseline_pre_3tier")
  // outcome-grading root fix (CID 2026-06-06T1600_metric-rootfix_c3d9) — additive,
  // legacy-safe expand. Both grader-populated (track-outcome.sh), writer never fills.
  //   - grader_verdict: deterministic 3-state advisory, SEPARATE from metric_pass
  //     (never overwrites the writer self-report — disagreement surfaces via review_flag).
  //   - downgrade_origin: provenance of how the graded outcome arose.
  // BOTH nullable: legacy rows (~2407 pre-fix) stay NULL = "not yet graded". The
  // task_type membership CHECK reuses the documented NOT VALID precedent (see the
  // attribution_source / baseline_pre_3tier comments above) — existing rows exempt,
  // VALIDATE deferred to post-verify gated on a zero-out-of-set audit (migration SQL).
  graderVerdict     GraderVerdict?   @map("grader_verdict")
  downgradeOrigin   DowngradeOrigin? @map("downgrade_origin")
  // TRUE = 오염 윈도우 격리 행 (2026-05-24 .. 2026-06-06 18:04 KST · metric_pass=false ·
  // grader_verdict NULL) — 학습 파이프라인 소비자가 제외해야 할 quarantine 플래그.
  // raw-SQL 런북(maintenance/poisoned-window-quarantine)만 set — writer/grader 미기입.
  poisonedWindow    Boolean       @default(false) @map("poisoned_window")
  insertedAt        DateTime      @default(now()) @map("inserted_at") @db.Timestamptz(6)

  correctionSignals CorrectionSignal[]

  @@unique([recordTs, agent, taskType], map: "outcomes_dedup")
  @@index([recordTs], map: "outcomes_ts_idx")
  @@index([agent, recordTs], map: "outcomes_agent_ts_idx")
  @@index([taskType, recordTs], map: "outcomes_task_ts_idx")
  // Partial index: review_flag = true only — used by §4.4 mismatch panel
  @@index([reviewFlag], map: "outcomes_review_flag_idx")
  // Cycle 3.3.a (2026-05-20): partial index `WHERE style_ref IS NOT NULL` on
  // (agent, record_ts DESC) — supports plan AC-B4 (c) 7-day rolling per-agent
  // aggregation during v1.0 OPTIONAL sparse-emission phase. Prisma 7 schema cannot
  // declare partial-index predicates → migration raw SQL only (see
  // 20260520144800_add_style_ref_to_outcomes/migration.sql CreateIndex block).
  // Index name: outcomes_style_ref_agent_ts_idx (NOT mirrored here intentionally —
  // declaring as plain @@index would cause prisma migrate diff to drop the partial
  // predicate and recreate as full index).
  @@map("outcomes")
  @@schema("core")
}

/// Source: outcome-record.sh stage1/stage2 capture (per plan §3.2 correction_signals)
model CorrectionSignal {
  id                 BigInt   @id @default(autoincrement())
  eventTs            DateTime @map("event_ts") @db.Timestamptz(6)
  taskType           String   @map("task_type") @db.VarChar(32)
  stage1Matched      Boolean  @map("stage1_matched")
  stage2Matched      Boolean  @map("stage2_matched")
  finalDetected      Boolean  @map("final_detected")
  revisionCountDelta Int      @map("revision_count_delta")
  outcomeId          BigInt?  @map("outcome_id")

  outcome Outcome? @relation(fields: [outcomeId], references: [id], onDelete: SetNull)

  @@unique([eventTs, taskType, outcomeId], map: "correction_signals_dedup")
  @@index([eventTs], map: "correction_signals_ts_idx")
  @@index([outcomeId], map: "correction_signals_outcome_idx")
  @@map("correction_signals")
  @@schema("core")
}

/// Source: learning-aggregator.py output (per plan §3.2 learning_log)
model LearningLog {
  id                   BigInt         @id @default(autoincrement())
  discoveredDate       DateTime       @map("discovered_date") @db.Date
  patternSignature     String         @map("pattern_signature")
  frequency            Int
  agent                String?        @db.VarChar(64)
  status               LearningStatus
  approvalTier         ApprovalTier   @map("approval_tier")
  lastUpdated          DateTime       @map("last_updated") @db.Timestamptz(6)
  /// 2026-05-04 #26-pre: status 전이 audit 컬럼. PATCH /api/learning/patterns/:id/status 활성화 (사용자 명시 §8 권한 가드).
  lastTransitionAt     DateTime?      @map("last_transition_at") @db.Timestamptz(6)
  lastTransitionReason String?        @map("last_transition_reason") @db.VarChar(500)

  @@unique([patternSignature], map: "learning_log_pattern_uniq")
  @@index([discoveredDate], map: "learning_log_date_idx")
  @@index([status, approvalTier], map: "learning_log_status_tier_idx")
  @@index([status, lastTransitionAt(sort: Desc)], map: "learning_log_status_transition_idx")
  @@map("learning_log")
  @@schema("core")
}

/// Source: autoagent + wiki + launchd 4-job daemons (per plan §3.2 daemon_runs,
/// revision 2 — flat statistics columns; PK = (run_date, daemon_name))
model DaemonRun {
  runDate            DateTime        @map("run_date") @db.Date
  daemonName         DaemonType      @map("daemon_name")
  startedAt          DateTime        @map("started_at") @db.Timestamptz(6)
  endedAt            DateTime?       @map("ended_at") @db.Timestamptz(6)
  status             DaemonStatus
  costGuardState     CostGuardState? @map("cost_guard_state")
  patchesCount       Int?            @map("patches_count")
  patchesApplyCount  Int?            @map("patches_apply_count")
  patchesRejectCount Int?            @map("patches_reject_count")
  deadlinksCount     Int?            @map("deadlinks_count")
  dedupCount         Int?            @map("dedup_count")
  // 위키 일일 컴파일 사이클 결과 — 04:00 wiki-daily-compile.sh 가 기록,
  // 04:30 _pg_push_wiki_cycle.py upsert 시 미포함 → NULL 보존 (partial-upsert 안전)
  compiledCount      Int?            @map("compiled_count")
  compiledTotal      Int?            @map("compiled_total")
  compileMs          BigInt?         @map("compile_ms")
  notes              String?
  insertedAt         DateTime        @default(now()) @map("inserted_at") @db.Timestamptz(6)

  payload DaemonRunPayload?
  // Note: autoagent_proposals.cycle_date is a logical FK (plan §3.2) — no Prisma
  // back-relation possible because daemon_runs PK is composite.

  @@id([runDate, daemonName], map: "daemon_runs_pkey")
  // Composite index for §4.9 daemon card latest-first listing
  @@index([daemonName, runDate(sort: Desc)], map: "daemon_runs_name_date_idx")
  // Partial index — abnormal cycles only (status <> 'ok')
  @@index([status, runDate(sort: Desc)], map: "daemon_runs_status_date_idx")
  @@map("daemon_runs")
  @@schema("core")
}

/// Source: daemon-reports/*.json raw view storage (per plan §3.2 daemon_run_payload,
/// revision 2 — separated from daemon_runs to avoid scan inflation)
model DaemonRunPayload {
  runDate          DateTime   @map("run_date") @db.Date
  daemonName       DaemonType @map("daemon_name")
  payload          Json       @db.JsonB
  payloadSizeBytes Int        @map("payload_size_bytes")

  daemonRun DaemonRun @relation(fields: [runDate, daemonName], references: [runDate, daemonName], onDelete: Cascade)

  @@id([runDate, daemonName], map: "daemon_run_payload_pkey")
  @@map("daemon_run_payload")
  @@schema("core")
}

/// Source: autoagent daemon patch proposals (per plan §3.2 autoagent_proposals,
/// revision 2 — promoted from SQLite to PG normalized table)
model AutoagentProposal {
  id              BigInt                 @id @default(autoincrement())
  cycleDate       DateTime               @map("cycle_date") @db.Date
  patternLabel    String                 @map("pattern_label") @db.VarChar(256)
  targetFile      String                 @map("target_file")
  targetAgent     String?                @map("target_agent") @db.VarChar(64)
  classification  ProposalClassification
  rationale       String?
  haikuStatus     String?                @map("haiku_status") @db.VarChar(32)
  approvalTier    ApprovalTier           @map("approval_tier")
  status          ProposalStatus
  proposedDiff    String?                @map("proposed_diff")
  costGuardState  String?                @map("cost_guard_state") @db.VarChar(16)
  reviewedAt      DateTime?              @map("reviewed_at") @db.Timestamptz(6)
  reviewedBy      String?                @map("reviewed_by") @db.VarChar(64)
  auditLogId      BigInt?                @map("audit_log_id")
  sourceFile      String                 @map("source_file")
  sourceFileMtime BigInt                 @map("source_file_mtime")
  indexedAt       DateTime               @default(now()) @map("indexed_at") @db.Timestamptz(6)

  // Phase 3 (2026-05-02 ADR R2 step 1) — pre-verify 4-axis verdict snapshot.
  // Mirrors PreVerifyResult fields in autoagent/daemon_cycle.py (C1=compliance-matrix,
  // C2=GLOBAL_RULES, C3=scope-*, C4=self-consistency). All nullable: existing rows
  // backfill to NULL; rows older than 2026-05-02 cycle were never pre-verified.
  // Why JSONB for axes: 4-key bool object preserves per-axis traceability for the
  // monitor UI's reject-reason panel without forcing 4 additional bool columns.
  preVerifyPassed    Boolean? @map("pre_verify_passed")
  preVerifyStatus    String?  @map("pre_verify_status") @db.VarChar(64)
  preVerifyRationale String?  @map("pre_verify_rationale")
  preVerifyAxes      Json?    @map("pre_verify_axes") @db.JsonB

  // Phase 2 (plan doc 1782 ADR-6) — confidence-weighted instinct learning loop.
  // Per-pattern AGGREGATE columns (not per-event → NOT on core.outcomes).
  // All nullable + forward-looking: daemon fills on next cycle, existing rows NULL.
  //   confidenceObserved — Beta posterior mean from empirical tuple (revision_count
  //     + result + evaluative_signal), NOT writer self-report (lib/confidence.py P2.3).
  //   projectKey — 12-char hex isolation key (lib/project_key.py 3-tier resolver P2.2).
  //   promotionTier — ladder state: mention/candidate/proposal/instruction-edit/skill-candidate (P3).
  confidenceObserved Float?  @map("confidence_observed") @db.Real
  projectKey         String? @map("project_key")
  promotionTier      String? @map("promotion_tier")

  // T12b backlog-drain — per-row cross-cycle stale counter. daemon-apply.sh's
  // stale-drain CTE increments this each consecutive stale re-selection and, at
  // STALE_DRAIN_THRESHOLD, flips status → 'snoozed' so the fossil stops cycling.
  // NOT NULL DEFAULT 0 (vs the sibling NULLable Phase columns): a stale counter
  // has a meaningful zero — every existing row starts at 0 attempts, no "unset".
  staleAttemptCount Int @default(0) @map("stale_attempt_count")

  // cycle_date references core.daemon_runs(run_date) WHERE daemon_name='autoagent'
  // — physical FK to composite PK omitted; relation is logical (per plan §3.2 note),
  // enforced by app-layer query (cycle_date + filter daemon_name='autoagent').
  // No Prisma `@relation` here because daemon_runs PK is composite (run_date, daemon_name).

  decisions AutoagentDecisionRecord[]

  // Dedup key for daemon UPSERT — _pg_dual_write_daemon.py:310 relies on this
  // ON CONFLICT (cycle_date, pattern_label, target_file). DB index pre-existed;
  // declared here in 20260509220000 to close Prisma↔DB schema drift.
  @@unique([cycleDate, patternLabel, targetFile], map: "autoagent_proposals_cycle_pattern_target_key")
  @@index([cycleDate], map: "autoagent_proposals_cycle_idx")
  // Partial index: pending review only
  @@index([status, approvalTier], map: "autoagent_proposals_status_tier_idx")
  @@index([targetAgent, cycleDate], map: "autoagent_proposals_agent_cycle_idx")
  // Phase 2 partial index autoagent_proposals_confidence_idx ON (confidence_observed)
  // WHERE confidence_observed IS NOT NULL (migration 20260524133000 raw SQL only —
  // Prisma 7 schema cannot declare partial-index predicates; plain @@index would make
  // migrate diff drop the partial predicate and regenerate a full mostly-NULL index).
  @@map("autoagent_proposals")
  @@schema("core")
}

/// Source: P3 git-free self-update pipeline — single-active-job tracker for the
/// route-enqueued updater. A crashed updater leaves a detectably-stale row
/// (heartbeat_at frozen), swept via the status index. Single-active-job is NOT
/// modeled here as @@unique: it is enforced by a hand-written raw-SQL PARTIAL
/// UNIQUE INDEX (WHERE status = 'in-progress') in this model's migration.sql.
model UpdateJob {
  id            BigInt          @id @default(autoincrement())
  status        UpdateJobStatus
  startedAt     DateTime        @map("started_at") @db.Timestamptz(6)
  // REQUIRED (non-null): the updater advances heartbeat_at while alive, so a
  // crash freezes it → the in-progress row is detectably stale to the sweep
  // (age(now(), heartbeat_at) filtered by status). A NULLable column would let
  // a crashed job masquerade as "never heartbeated" and evade the sweep.
  heartbeatAt   DateTime        @map("heartbeat_at") @db.Timestamptz(6)
  targetVersion String          @map("target_version")
  failureReason String?         @map("failure_reason")
  // Restart-resilient preview-nonce store — survives the updater self-restart.
  // NOT a before-image: rollback recovery uses the agents-bak snapshot, so no
  // pre_change/before-image column exists here (state-tracking only).
  previewNonce  String?         @map("preview_nonce")

  // Stale-sweep support (age(now(), heartbeat_at) filtered by status).
  // Single-active-job is enforced by the raw-SQL partial UNIQUE INDEX
  // update_job_single_active_uniq (WHERE status = 'in-progress') in the
  // migration — deliberately NOT mirrored as @@unique here: Prisma 7 cannot
  // express a partial predicate, so migrate diff would drop the WHERE clause
  // and regenerate a full unique index. Mirrors the intentional
  // outcomes_style_ref_agent_ts_idx / autoagent_proposals_confidence_idx pattern.
  @@index([status], map: "update_job_status_idx")
  @@map("update_job")
  @@schema("core")
}

