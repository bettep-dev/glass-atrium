#!/usr/bin/env bash
# glass-atrium — the SOLE entry point for the Glass Atrium harness.
#
# The MENU is the entire user-facing interface. `./glass-atrium` (no args) launches
# an arrow-key TUI menu (alternate screen, raw single-key input from /dev/tty) whose
# live progress pane runs each engine STEP directly and stamps a glyph per step —
# no subprocess, no STDERR-marker parsing. There is NO user-facing subcommand surface.
#
# Sources the install/uninstall ENGINE (lib/ga-core.sh) and drives it IN-PROCESS.
#
# Design movement: "Lithography" — the monospace cell grid as a hard surface,
# every glyph incised, nothing decorative. Triple-redundant selection signal
# (caret + reverse-video + accent color) degrades cleanly to caret + reverse
# under NO_COLOR, and to plain text on a non-TTY.
#
# Menu -> engine step sequence:
#   Install     -> deps preflight + run_install/run_bootstrap steps (install base +
#                  monitor build + health gate) THEN an 11th step that registers the 8
#                  launchd jobs (menu auto-loads launchd; opt out via GA_NO_LOAD_LAUNCHD=1
#                  / --no-load-launchd); DB bootstrap is one of the install steps
#   Uninstall   -> run_uninstall steps (remove symlinks + un-wire hooks; purge via prompt)
#   Token Setup -> preflight_provision_headless_token ONLY (headless launchd OAuth
#                  token: claude setup-token -> 0600 render -> self-test; idempotent)
#   Quit        -> trap-clean exit
#
# INTERNAL/UNDOCUMENTED passthrough: `glass-atrium <subcommand> [args]` still dispatches
# to the matching engine function in-process. It is NOT a user-facing surface (absent
# from --help) — it is retained solely so the test/E2E harnesses (oss-e2e-bootstrap.sh,
# render-launchd-plists.bats, install-prune.bats) can drive discrete engine functions
# without the TUI. End users invoke ONLY `./glass-atrium`.
#
# Capability ladder (4 tiers): truecolor (COLORTERM) -> 256 -> 16 -> mono.
# NO_COLOR / non-TTY / --ascii force the lower tiers; raw mode is NEVER entered
# on a non-TTY.
#
# Usage:
#   glass-atrium                 launch the interactive menu (the only invocation)
#   glass-atrium --ascii         launch the menu with ASCII glyphs + mono palette
#   glass-atrium -h | --help     usage
#
# Exit codes:
#   0    clean exit
#   1    engine die() (rendered inline, not a launcher crash)
#   2    usage error / not a TTY for the interactive menu
#   20-24 named engine/preflight codes (propagated through the internal passthrough)
#
# HARD CONSTRAINT: bash 3.2 compatible (macOS /bin/bash 3.2.57). No mapfile, no
# associative arrays, no fractional `read -t`. BSD coreutils only.
#
# Two optional (--enable=all) checks are disabled file-wide, by design:
#   SC2312 — the c() color helper is deliberately invoked inside strings;
#            it always succeeds (printf), so its return value carries no signal.
#   SC2310 — `func || status=$?` is the intended exit-capture idiom for the engine
#            steps; disabling set -e there is the point (we render the exit, never
#            abort the launcher on a step failure).
# shellcheck disable=SC2312,SC2310
set -Eeuo pipefail
IFS=$'\n\t'

# --- self-resolution + engine source ---------------------------------------
# Resolve our own dir so lib/ga-core.sh is found whether invoked from the repo
# root or via a symlink farm into ~/.claude. readlink -f is unavailable on BSD,
# so walk the symlink chain manually. GA_DIR is OUR var name (the lib owns GA_ROOT,
# a DIFFERENT name) — keeping it readonly is safe (no collision with the lib's
# sentinel-guarded GA_ROOT readonly, the Stage-1 lesson being about GA_ROOT only).
resolve_self() {
  local src="${BASH_SOURCE[0]}" dir
  while [[ -L "${src}" ]]; do
    dir="$(cd -- "$(dirname -- "${src}")" >/dev/null 2>&1 && pwd -P)"
    src="$(readlink -- "${src}")"
    [[ "${src}" != /* ]] && src="${dir}/${src}"
  done
  cd -- "$(dirname -- "${src}")" >/dev/null 2>&1 && pwd -P
}
GA_DIR="$(resolve_self)"
readonly GA_DIR

# shellcheck source=lib/ga-core.sh
source "${GA_DIR}/lib/ga-core.sh"
# ga_init_env is the SOLE readonly site for GA_ROOT — pass OUR resolved dir, never
# pre-readonly a GA_ROOT here (the Stage-1 readonly-collision lesson). The lib owns
# all engine constants + run-mode flag DEFAULTS; ga_parse_args sets the flags.
ga_init_env "${GA_DIR}"

# Source the bare-Mac dependency-bootstrap DETECTION + command-string layer AFTER
# ga_init_env (it reads no engine constants, but the source-after-init ordering keeps
# the contract: engine first, then the deps layer the entry point drives). ga-deps.sh
# is PURE (read-only detects + command-string builders, NO TUI) — the consent-gate
# orchestration + every prompt below lives HERE, where the TUI helpers exist.
# shellcheck source=lib/ga-deps.sh
source "${GA_DIR}/lib/ga-deps.sh"

# Source the launcher-own TUI modules (byte-identical extractions of the former
# inline concerns): capability detection, render primitives, terminal lifecycle +
# input. Pure function-definition siblings — no shebang / set -Eeuo / IFS / trap of
# their own (those stay loader-owned so re-sourcing never re-arms them). Sourced
# HERE, before the cleanup trap is armed, so its tp/restore_terminal callees are
# already defined the moment the trap can fire. Order-independent: the moved fns
# read the loader's file-scope globals (TTY, PLATE_*, C_*/G_*, USE_*) at call time.
# shellcheck source=lib/ga-tui-caps.sh
source "${GA_DIR}/lib/ga-tui-caps.sh"
# shellcheck source=lib/ga-tui-primitives.sh
source "${GA_DIR}/lib/ga-tui-primitives.sh"
# shellcheck source=lib/ga-tui-term.sh
source "${GA_DIR}/lib/ga-tui-term.sh"
# shellcheck source=lib/ga-tui-frame.sh
source "${GA_DIR}/lib/ga-tui-frame.sh"
# shellcheck source=lib/ga-tui-workbox.sh
source "${GA_DIR}/lib/ga-tui-workbox.sh"
# shellcheck source=lib/ga-tui-run.sh
source "${GA_DIR}/lib/ga-tui-run.sh"
# shellcheck source=lib/ga-tui-monitor.sh
source "${GA_DIR}/lib/ga-tui-monitor.sh"
# shellcheck source=lib/ga-tui-dispatch.sh
source "${GA_DIR}/lib/ga-tui-dispatch.sh"
# shellcheck source=lib/ga-tui-preflight.sh
source "${GA_DIR}/lib/ga-tui-preflight.sh"

# --- temp + cleanup --------------------------------------------------------
# The engine functions assign these atomic-write staging temps (swap_symlink sets
# STAGE_TMP; render_config/wire_hooks set RENDER_TMP; bootstrap_health_gate sets
# GATE_LOG). As the SOLE entry point we now own their trap sweep so an INT/TERM
# mid-write never leaves a .ga-render/.ga-wire/.ga-gate orphan. Declared here so
# set -u never trips on a first-reference and the trap can sweep them.
STAGE_TMP=""
RENDER_TMP=""
GATE_LOG=""
STEP_LOG_CUR="" # IMP1: in-flight run_step stderr-capture temp; cleanup sweeps it on abort
# CHANGE 2 (fake-hang reap) reads SPIN_PID in cleanup() — armed at file scope ~L259, but
# the forked step spinner is not started until run_plan (~L1644). Declare it HERE with the
# other cleanup-touched globals so a signal (Ctrl-C/TERM) in the startup window before the
# spinner ever forks cannot trip set -u inside cleanup()'s `[[ -n "${SPIN_PID}" ]]` guard.
SPIN_PID="" # forked step-spinner PID; "" = no spinner running (cleanup/stop_step_spinner reset)
# IDLE_PID — forked IDLE-spinner PID (async-feel: animates the otherwise-blank blocking windows
# — detection / count-and-gate / monitor-stop gates / preflight->run_plan handoff). Distinct from
# SPIN_PID so cleanup() reaps EITHER independently, and the single-active-spinner invariant is held
# by defensive cross-stops (start_step_spinner + preflight_bracket + _confirm_pregate all
# stop_idle_spinner first) — the idle + step spinners NEVER animate the same box body concurrently.
# Declared HERE with the other cleanup-touched globals so a signal in the startup window (before any
# idle fork) cannot trip set -u inside cleanup()'s `[[ -n "${IDLE_PID}" ]]` guard.
IDLE_PID="" # forked idle-spinner PID; "" = no idle spinner running (cleanup/stop_idle_spinner reset)

# Dependency-preflight named exit code (distinct from the engine's bootstrap 20-23
# band + die's generic 1): emitted when the preflight cannot proceed — a missing
# auto-installable dep with no TTY to consent on, a declined hard gate (Xcode CLT /
# claude auth), or a fatal install. Loud-fail per shared-self-improve-hygiene
# Precondition Loud-Fail (no silent absorption of an unmet entry condition).
readonly PREFLIGHT_EXIT_BLOCKED=24

# Preflight TTY state — the passthrough `bootstrap` path has no ui_init, so the
# preflight opens its own /dev/tty (fd 4) when one is available. Set by
# preflight_ensure_tty; consumed by the preflight prompt/run helpers.
PREFLIGHT_TTY_OWNED=false      # true when WE opened fd 4 (must close on cleanup)
PREFLIGHT_NONINTERACTIVE=false # true when no controlling TTY is reachable

# IMP2 launchd-monitor stop/restore state — the install health gate cannot validate
# the fresh build while a launchd monitor still serves :16145. The install path stops a
# launchd-OWNED monitor before run_plan and restores it after; cleanup() is the backstop
# restorer on any die/exit/INT/TERM. File-scope so cleanup() (which survives a bare engine
# `exit`, where a function-local trap cannot fire) reads them — same pattern as GATE_LOG.
MONITOR_WAS_STOPPED="" # "yes" only between a successful stop and its restore
MONITOR_PLIST_PATH=""  # captured at stop so restore can re-bootstrap without re-deriving

# Menu install-panel gate-capture temp. The install panel's PRE/POST gates
# (dependency preflight, launchd/orphan monitor stop, monitor restore) run OUTSIDE
# run_step, so their engine log() lines (stderr) would scribble the alt-screen +
# scroll it (the path-like leak + the post-run nav frame corruption). run_gate_quiet
# routes their fd 2 here so the alt-screen stays clean; the lines stay PRESERVED for
# loud-fail diagnostics (surfaced on a gate failure). File-scope so cleanup() sweeps
# it on any abort. CLI/passthrough is UNTOUCHED — these gates keep emitting to the
# real stderr there (no run_gate_quiet wrap on that path).
GATE_QUIET_LOG=""

# --- global UI state (set by ui_init / drawn by render loop) ---------------
TTY_SAVED=""      # stty -g snapshot, restored on every exit path
RAW_ACTIVE=false  # true while raw mode + alt-screen are engaged
SELECTED=0        # current menu index
USE_COLOR=false   # color escapes permitted
USE_UTF8=false    # box-drawing + caret glyphs permitted
COLOR_TIER="mono" # truecolor | 256 | 16 | mono (informational)

# run_plan render mode (install single-line progress). Empty = the historical
# scrolling-log model (one resolved row per step, fd-2-only capture) — uninstall
# leaves this empty so it is byte-for-byte unchanged. Only dispatch_action's
# install branch sets it to "install" via run_plan's 3rd arg; it gates BOTH the fd-1+fd-2
# merge capture AND the in-place single-line redraw in run_step.
RENDER_MODE=""

# brand palette, resolved once per tier into raw SGR parameter strings (the part
# between ESC[ and m). Empty string = no color for that role.
C_ACCENT="" # #60A5FA active/selection
C_ALERT=""  # #FBBF24 alert/destructive/error
C_INFO=""   # #6a9bcc info/link
C_OK=""     # #788c5d success
C_STRONG="" # #faf9f5 strong text
C_DIM=""    # #b0aea5 dim text / subtitle
C_FRAME=""  # #e8e6dc frame
C_DANGER="" # #EF4444 destructive-row focus

# box-drawing + status glyphs — SoT lives in resolve_glyphs, which assigns EVERY one
# of these per tier (UTF-8 or ASCII fallback) before any consumer runs (run_menu is the
# only G_* reader; the passthrough path returns before resolve_glyphs and reads none).
# Declared empty at file scope ONLY so `set -u` never trips on a first-reference — the
# values are NOT defaults (resolve_glyphs is unconditional), so they are NOT duplicated
# here. One source of truth shared by the wordmark, the framed menu, and the run-plan
# section/outcome panels so a single --ascii toggle degrades them all.
G_TL=""      # top-left corner
G_TR=""      # top-right corner
G_BL=""      # bottom-left corner
G_BR=""      # bottom-right corner
G_H=""       # horizontal rule
G_V=""       # vertical rail
G_DOT=""     # mid-dot separator
G_CARET=""   # selection caret
G_OK=""      # step / outcome success glyph
G_FAIL=""    # step / outcome fail glyph
G_ARROW_U="" # keyhint up
G_ARROW_D="" # keyhint down
G_ENTER=""   # keyhint select

# spinner + progress-bar glyph sets, also assigned by resolve_glyphs (the SoT). The
# spinner is a fixed-display-width frame sequence (one braille cell per frame so the
# status line never jitters); the progress glyphs are the sub-cell block ladder.
# ASCII fallbacks are pure 7-bit. SPIN_FRAMES is a space-joined string (bash-3.2 has
# no per-element array sharing across the helper boundary; the spinner word-splits it).
# Declared empty here for the same set -u reason as the G_* block above.
SPIN_FRAMES="" # space-joined frames; assigned per tier by resolve_glyphs
# SPIN_SLOW_DIV — the SLOW-cadence divisor decoupling the work-box LINE 2 detail (output tail
# refresh / dots animation) from the 100ms spinner FRAME tick. LINE 1 (bar + i/N + label) repaints
# every 100ms tick to stay alive; LINE 2 recomputes only when `tick % SPIN_SLOW_DIV == 0` — 6 ticks
# ≈ 600ms, a calm/readable cadence inside the 500ms-1s band (never the buggy per-100ms label roll),
# AND it throttles the STEP_LOG_CUR tail fork to ~2/sec instead of 10/sec (no per-tick subprocess
# storm). The dots phase is (tick / SPIN_SLOW_DIV) % 3 → '.'/'..'/'...' (see _spinner_dots).
readonly SPIN_SLOW_DIV=6
# PROG_FULL/PROG_EMPTY are the shared progress-bar glyph SoT, consumed by the block-bar
# step counter (build_counter_str); resolved per tier in resolve_glyphs so --ascii
# degrades them.
PROG_FULL=""  # filled progress cell
PROG_EMPTY="" # empty progress cell

# Shared claude-auth-failure signature SoT — the CLI-output alternation common to the
# headless self-test (headless_auth_selftest) and the doctor advisory's report scan
# (doctor_headless_auth_advisory), so a future provider wording change is edited once
# instead of drifting between two in-file greps (they had already diverged on 401|403
# vs 40[13] and the Failed-to-authenticate clause). The advisory layers its report-JSON-
# only signatures (parse_mode/explicit_state/haiku-exit) ON TOP of this core. Mirrors the
# daemon_cycle.py _HAIKU_AUTH_PATTERNS upstream reference (no shared runtime — kept
# conceptually anchored by this comment, not unified across languages).
readonly AUTH_FAIL_RE='API Error: *(401|403)|HTTP *(401|403)|Invalid authentication credentials|Failed to authenticate'

# unified cleanup — restores the terminal AND sweeps any leftover engine staging
# temp from an interrupted swap/render/wire/gate. Idempotent + exit-code preserving
# (the EXIT trap re-raises the original status). Armed at file scope so a die()
# inside a passthrough engine call (no ui_init) still sweeps the temps; the
# terminal restore is a no-op unless ui_init engaged raw mode.
cleanup() {
  local exit_code=$?
  # CHANGE 2 (fake-hang reap): kill the forked step spinner FIRST, before anything
  # below can early-return. A step function's die()/exit() (e.g. bootstrap_health_gate's
  # orphan-port precondition) exits the WHOLE process — run_step's set +e does NOT catch
  # an `exit`, so control never reaches stop_step_spinner (run_step ~L2044) and the
  # forked spinner keeps animating = a fake "infinite hang". Reaping it here converts ANY
  # step exit into a clean stopped frame. IDEMPOTENT + safe when SPIN_PID is unset/dead:
  # the [[ -n ]] guard skips the no-spinner case, kill -0 probes liveness, and every
  # command is masked so a stray non-zero can NEVER corrupt the preserved exit_code under
  # set -e (the EXIT trap re-raises ${exit_code} at the end). No blanket `wait` — only the
  # spinner PID is targeted (a blanket wait could drain unrelated background work).
  if [[ -n "${SPIN_PID}" ]]; then
    kill "${SPIN_PID}" 2>/dev/null || true          # SIGTERM → the spinner's INT/TERM trap restores cnorm + exits
    kill -0 "${SPIN_PID}" 2>/dev/null && kill -KILL "${SPIN_PID}" 2>/dev/null || true # SIGKILL only if still alive (untrappable)
    wait "${SPIN_PID}" 2>/dev/null || true          # reap ONLY the spinner PID
    SPIN_PID=""
  fi
  # Same reap for the forked IDLE spinner (async-feel animator): a die()/exit() mid-idle-window
  # (e.g. a preflight gate aborting the whole process) would otherwise leave the idle child
  # animating a torn-down frame. Idempotent + safe when IDLE_PID is unset/dead — every command
  # masked so a stray non-zero cannot corrupt the preserved exit_code under set -e.
  if [[ -n "${IDLE_PID}" ]]; then
    kill "${IDLE_PID}" 2>/dev/null || true          # SIGTERM → the idle spinner's INT/TERM trap restores cnorm + exits
    kill -0 "${IDLE_PID}" 2>/dev/null && kill -KILL "${IDLE_PID}" 2>/dev/null || true # SIGKILL only if still alive (untrappable)
    wait "${IDLE_PID}" 2>/dev/null || true          # reap ONLY the idle spinner PID
    IDLE_PID=""
  fi
  # VR-10 cursor safety: cnorm UNCONDITIONALLY, OUTSIDE the RAW_ACTIVE guard. A step
  # spinner hides the cursor (civis) while dispatch_action has already set
  # RAW_ACTIVE=false → restore_terminal early-returns and would SKIP cnorm, leaving an
  # invisible cursor at the shell prompt after a Ctrl-C mid-spinner. This unconditional
  # cnorm closes that footgun on every EXIT/INT/TERM regardless of raw-mode state.
  tp cnorm
  restore_terminal
  [[ -n "${STAGE_TMP}" && -L "${STAGE_TMP}" ]] && rm -f -- "${STAGE_TMP}"
  [[ -n "${RENDER_TMP}" && -f "${RENDER_TMP}" ]] && rm -f -- "${RENDER_TMP}"
  # CHANGE 4 (clean failure, NOT a silent kill): when a step function die()s/exit()s
  # mid-run, the process exits past run_step's classify/_dump_step_log (set +e does not
  # catch an `exit`), so the captured step log (STEP_LOG_CUR, still set while the step is
  # in flight) would be swept below with its FATAL diagnostic NEVER shown — a SILENT kill.
  # On an abnormal exit (non-zero) surface that captured output to stderr FIRST, so the
  # operator sees WHY the install died (e.g. bootstrap_health_gate's port/build FATAL).
  # This is the deliberate NON-subshell CHANGE-4 path: it reads only the existing globals
  # (exit_code + STEP_LOG_CUR) — it does NOT subshell-isolate any STEP_FN, so steps that
  # mutate parent-shell globals (RENDER_TMP, STEP_*, STAGE_TMP, GATE_LOG, MONITOR_*) keep
  # mutating the parent shell (a subshell would lose those = regression). For the gate
  # specifically, GATE_LOG is a parent global the parent cleanup sweeps (L below) — proof
  # that even the gate step cannot be safely subshelled. tail (bounded) avoids dumping a
  # huge build log; masked so a read error never corrupts the preserved exit_code.
  if [[ "${exit_code}" -ne 0 && -n "${STEP_LOG_CUR}" && -f "${STEP_LOG_CUR}" && -s "${STEP_LOG_CUR}" ]]; then
    printf 'FATAL: install step aborted (exit %s) — last output:\n' "${exit_code}" >&2
    tail -n 30 -- "${STEP_LOG_CUR}" >&2 2>/dev/null || true
  fi
  [[ -n "${GATE_LOG}" && -f "${GATE_LOG}" ]] && rm -f -- "${GATE_LOG}"
  [[ -n "${GATE_QUIET_LOG}" && -f "${GATE_QUIET_LOG}" ]] && rm -f -- "${GATE_QUIET_LOG}"
  [[ -n "${STEP_LOG_CUR}" && -f "${STEP_LOG_CUR}" ]] && rm -f -- "${STEP_LOG_CUR}"
  # IMP2 backstop: restore a launchd monitor the install stopped, on ANY exit path
  # (die/exit/INT/TERM). Idempotent — the happy-path restore clears MONITOR_WAS_STOPPED,
  # so this is a no-op after a normal restore and the SOLE restorer when the install
  # exited (engine die) before its happy-path restore. `|| true` is belt-and-suspenders:
  # restore already returns 0 unconditionally, but a stray non-zero must never skip the
  # cnorm/temp restore above or corrupt the preserved exit code under set -e.
  restore_launchd_monitor || true
  # close the preflight's own /dev/tty fd if it (the passthrough path) opened one.
  [[ "${PREFLIGHT_TTY_OWNED}" == "true" ]] && exec 4>&- 2>/dev/null || true
  exit "${exit_code}"
}
trap cleanup EXIT INT TERM
trap 'echo "ERROR: line ${LINENO}: ${BASH_COMMAND}" >&2' ERR

# --- menu model (parallel arrays — bash-3.2 has no assoc arrays) ------------
# Index-aligned: label / description / action keyword / destructive flag. MENU_COUNT
# MUST equal every array's length; redraw_frame_inplace repositions by cursor save/restore so
# it is immune to the count, but draw_menu iterates [0, MENU_COUNT) — keep them in sync.
readonly -a MENU_LABEL=(
  "Install"
  "Token Setup"
  "Monitor"
  "Uninstall"
  "Quit"
)
readonly -a MENU_DESC=(
  "full bootstrap: deps + install + build + health gate"
  "provision the headless launchd OAuth token only"
  "open the monitor dashboard in your browser"
  "remove symlinks · --purge for config"
  "exit launcher"
)
readonly -a MENU_ACTION=(
  "install"
  "token-setup"
  "monitor"
  "uninstall"
  "quit"
)
# 1 = can prompt for a destructive confirmation (quiet accent-dot cue).
readonly -a MENU_DESTRUCTIVE=(
  0
  0
  0
  1
  0
)
readonly MENU_COUNT=5

# === the Lithograph one-plate system =======================================
# ONE canonical inner-width SoT (plate_inner) + ONE row/top/bottom emitter trio
# (plate_row / plate_top / plate_bot) shared by the wordmark, the menu, and the
# run-plan section/outcome panels. Before this, three disagreeing width models
# (a 47-magic wordmark, a 49 bar, a right-rail-less menu, a stray-leading-H
# section banner) desynced the boxes; routing every box through these helpers
# guarantees all rails/corners land on the same left + right columns (the plate).
#
# PLATE_MARGIN — the minimum left gutter (in cells) + the compact-fallback indent.
# The plate emitters pad to PLATE_LEFT (below), which DEFAULTS to PLATE_MARGIN so the
# inline-run/panel path (compact, top-left) is byte-for-byte unchanged; the fullscreen
# menu raises PLATE_LEFT to the centered column before drawing + restores it after.
readonly PLATE_MARGIN=2

# Fullscreen-layout constants (the centered max-width column). MAX_READABLE is the
# plate OUTER cap (incl. both rails) so very-wide text never stretches past 64 cells
# even on a 200-col screen; MIN_COLS/MIN_ROWS gate the degradation to the compact
# top-left layout. MIN_ROWS DERIVES from the same terms as block_rows in
# compute_menu_geometry — wordmark(5)+sep(1)+menu(2 rails+MENU_COUNT)+1 gap+workbox(4) =
# block_rows, +3 for the top gap + bottom keyhint gap (= 22 at MENU_COUNT=6), so it
# auto-tracks MENU_COUNT. MIN_COLS=50 gates fullscreen so the 44-col BORDERLESS banner
# (emitted past plate_truncate at PLATE_LEFT) always fits without wrapping into the
# absolute-anchored menu, while inner stays >=44 for the 14-cell label + caret gutter.
# (MENU_COUNT is defined above, so this readonly computes safely at file-scope.)
readonly MAX_READABLE=64
readonly MIN_COLS=50
readonly MIN_ROWS=$((5 + 1 + (2 + MENU_COUNT) + 1 + 4 + 3))

# PLATE_LEFT — the live left-indent every plate emitter pads to. Default = PLATE_MARGIN
# (the compact / inline-run path). draw_menu raises it to the centered column for the
# fullscreen menu block, then restores it to PLATE_MARGIN so the inline-run panels keep
# their 2-cell indent (untouched scope).
PLATE_LEFT="${PLATE_MARGIN}"
# MENU_INNER_OVERRIDE — when non-empty, plate_inner returns it verbatim (the fullscreen
# centered-column inner width). Empty = the historical term_cols-driven width SoT. Set
# by draw_menu's fullscreen branch around the block, cleared after.
MENU_INNER_OVERRIDE=""

# === low-level terminal output ============================================
# All launcher chrome is written DIRECTLY to /dev/tty (TTY), never stdout/stderr,
# so an engine step's STDERR log() stream can never scribble over our frozen
# header. tty_out is the single sink for the menu + wordmark.
TTY=""
# === fullscreen menu geometry =============================================
# The centered-column layout state. FULLSCREEN gates the whole responsive path: false
# = the compact top-left layout (tiny terminal / missing cursor-addressing), unchanged
# from before. The remaining vars are recomputed by compute_menu_geometry on every
# (re)draw + on WINCH, so a resize repositions the block with no stale values.
FULLSCREEN=false            # true when the centered fullscreen layout is active
# GEOMETRY_DIRTY — the cache-gate flag (ITEM 1 flicker fix). compute_menu_geometry RE-READS
# the live TTY winsize (stty/tput), and a transient odd read shifts MENU_FIRST_ROW by a row →
# a 1-row nav oscillation. So geometry is now computed ONCE (init) + only again on SIGWINCH:
# ensure_geometry recomputes ONLY when this is true, then clears it. Nav/dim/done/return leave
# it false → the cached MENU_*/WORKBOX_* anchors are reused verbatim (no per-keypress size read).
GEOMETRY_DIRTY=true
MENU_LEFT="${PLATE_MARGIN}" # centered left column the block pads to
MENU_INNER=52               # centered-column inner width (caps at MAX_READABLE-2)
MENU_FIRST_ROW=1            # 1-based screen row the wordmark top rail starts on
MENU_KEYHINT_ROW=1          # 1-based screen row the bottom-pinned keyhint sits on
# Menu-block + workbox anchors, derived by compute_menu_geometry from MENU_FIRST_ROW +
# the fixed wordmark(5)+separator(1) stack and MENU_COUNT — shared by draw_menu, draw_workbox,
# and the per-tick spinner (which repaints WORKBOX_BODY_ROW in place inside the stable frame).
