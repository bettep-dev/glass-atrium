# === INTERNAL passthrough (undocumented — test/E2E harnesses only) ===========
# NOT a user-facing surface: end users invoke ONLY `./glass-atrium` (the menu). This
# `glass-atrium <subcommand> [args]` dispatch is retained so the test harnesses can
# drive discrete engine functions without the TUI (oss-e2e-bootstrap.sh -> install /
# uninstall; render-launchd-plists.bats -> render-plists; install-prune.bats -> prune).
# One documented operator surface rides the same dispatch: `glass-atrium migrate`
# (re)runs the legacy-farm layout migration standalone for an existing deployment
# (honors --dry-run; also armed inside every install — see migrate_layout's
# CALL-SITES contract in lib/ga-core.sh).
# It parses the flags in-process (the engine's argv parsing) and calls the matching
# engine function directly — no subprocess. The lib's run-mode flag vars (set here)
# carry every option to the engine. Named exit codes propagate from the engine
# verbatim (bootstrap 20-23, prune 2-3, db 3-9, die generic 1).

# ga_parse_args — set the lib's run-mode flag vars from the flag tokens, leaving
# the subcommand to the caller (already peeled off). Both the install-side flags
# (--dry-run/--repoint-launchd/--load-launchd/--no-load-launchd/--re-render/
# --collision-prompt/--recreate-db/--recreate-yes) and the uninstall-side flags
# (--orphan-scan/--purge-config/--verify-clean/--yes) are recognized; an unknown
# flag is a loud die. --no-load-launchd is the CHANGE 1 opt-out for the menu's
# auto-load 11th step (inert on the passthrough path, which loads only behind
# --load-launchd); accepting it here keeps a CI harness that drives the menu's
# step plan able to suppress the load.
ga_parse_args() {
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --dry-run) DRY_RUN=true ;;
      --repoint-launchd) REPOINT_LAUNCHD=true ;;
      --load-launchd) LOAD_LAUNCHD=true ;;
      --no-load-launchd) NO_LOAD_LAUNCHD=true ;;
      --re-render) RE_RENDER=true ;;
      --collision-prompt) COLLISION_PROMPT=true ;;
      --recreate-db) RECREATE_DB=true ;;
      --recreate-yes) RECREATE_YES=true ;;
      --orphan-scan) SCAN_ONLY=true ;;
      --purge-config) PURGE_CONFIG=true ;;
      --verify-clean) VERIFY_CLEAN=true ;;
      --yes) ASSUME_YES=true ;;
      *) die "unknown argument: $1" ;;
    esac
    shift
  done
}

# passthrough — dispatch a subcommand to its engine function in-process. The
# subcommand vocabulary IS the engine's argv contract; --verify-clean /
# --orphan-scan / --purge-config select the uninstall sub-modes (matching the
# engine's uninstall mode dispatch). Each engine
# function's named exit codes propagate through (set -e off via `|| status=$?`
# is NOT used — we WANT the engine's exit/die to set our exit status directly).
passthrough() {
  # The `update` subcommand (T08) forwards its args VERBATIM to the glass-atrium-update
  # updater (T09), which owns its own argv parsing (--help, positionals). It MUST stay
  # FIRST-token + verbatim-forward (the installer's flag parser loud-dies on the
  # updater's own tokens), so it is detected on the RAW first token BEFORE the
  # position-independent split below — the split's extra-arg guard must never touch the
  # updater's private argv. Capture the rc via `|| rc=$?` so set -e never aborts on a
  # non-zero engine exit, then `exit` it directly (the bootstrap branch's terminal
  # idiom): a non-zero `return` would trip the ERR trap, whereas `exit` propagates the
  # updater's code cleanly and cleanup() (EXIT trap) still restores the terminal.
  if [[ "$1" == "update" ]]; then
    shift
    local update_rc=0
    run_update "$@" || update_rc=$?
    exit "${update_rc}"
  fi

  # Position-independent token split (non-update engine subcommands): the SUBCOMMAND is
  # the first NON-flag token (anything not matching -*), every other token is a flag
  # routed to ga_parse_args. This accepts both `prune` and the natural flag-first
  # ordering `--dry-run prune` (install-prune.bats test 5) as well as `prune --dry-run`
  # — the subcommand may sit anywhere in argv relative to its flags. bash-3.2 safe (no
  # getopt long-opt support): a manual single pass builds the flag list + captures the
  # lone subcommand.
  local sub="" pt_flags=() tok
  for tok in "$@"; do
    if [[ "${tok}" == -* ]]; then
      pt_flags+=("${tok}")
    elif [[ -z "${sub}" ]]; then
      sub="${tok}"
    else
      # A second non-flag token has no meaning in the subcommand contract (one engine
      # function per invocation) — loud-fail rather than silently dropping it.
      die "unexpected extra argument: ${tok}"
    fi
  done
  [[ -n "${sub}" ]] || die "no subcommand given"

  # parse the peeled flag tokens into the lib's run-mode vars. The `${arr[@]+"${arr[@]}"}`
  # guard is the bash-3.2-safe empty-array expansion under set -u (a bare "${pt_flags[@]}"
  # trips nounset when the array is empty, e.g. the flagless `prune` path).
  ga_parse_args ${pt_flags[@]+"${pt_flags[@]}"}

  case "${sub}" in
    bootstrap)
      # ALWAYS-ON dependency preflight FIRST (the bare-Mac bootstrap layer). On a
      # provisioned machine it is a fast no-op; on a bare Mac it drives the
      # consent/guide flow. A non-zero return blocks bootstrap with a named exit
      # code (loud-fail — no silent absorption of an unmet entry condition).
      run_dependency_preflight || exit "${PREFLIGHT_EXIT_BLOCKED}"
      run_bootstrap
      ;;
    install) run_install ;;
    doctor)
      # run_doctor sets the exit code; the headless-auth advisory is APPENDED
      # non-fatally (it never changes the doctor verdict). Capture rc, run the
      # advisory, then propagate the ORIGINAL rc.
      local doctor_rc=0
      run_doctor || doctor_rc=$?
      doctor_headless_auth_advisory
      return "${doctor_rc}"
      ;;
    preflight) run_doctor ;;
    wire-hooks) wire_hooks ;;
    render-config) render_config ;;
    render-plists) render_plists ;;
    db-setup) run_db_setup ;;
    agents-only) run_agents_only ;;
    migrate) migrate_layout ;;
    prune) run_prune ;;
    uninstall)
      # uninstall sub-modes: --verify-clean and --orphan-scan are
      # mutually-exclusive standalone modes; the default is the full removal
      # path. The target-home precondition gates every sub-mode.
      [[ -d "${TARGET_HOME}" ]] || die "target home missing: ${TARGET_HOME}"
      if "${VERIFY_CLEAN}"; then
        verify_clean
      elif "${SCAN_ONLY}"; then
        log "== uninstall: orphan-scan (no removal) target=${TARGET_HOME} =="
        remove_manifest_links
        sweep_orphans
        log "== uninstall: orphan-scan done (no mutation) =="
      else
        # Full removal is destructive (drops the glass_atrium + shadow DBs, deletes
        # monitor/node_modules). On this non-interactive CLI passthrough require an
        # explicit --yes; a --dry-run run is non-destructive (drop/rm skip under
        # DRY_RUN) so it is allowed without --yes. The interactive menu's "remove"
        # pregate is the consent for the TUI path — this gate guards ONLY the headless
        # passthrough, and does NOT refuse the drop (the auto-drop is intended).
        if ! "${DRY_RUN}" && ! "${ASSUME_YES}"; then
          die "uninstall: destructive (drops glass_atrium + shadow DBs, deletes monitor/node_modules). Re-run with --yes, or use the interactive menu."
        fi
        run_uninstall
      fi
      ;;
    *)
      # The passthrough is internal/undocumented (test harnesses only); end users
      # run the menu. An unknown internal token is a harness error — point at the menu.
      printf 'glass-atrium: unknown internal subcommand: %s\n' "${sub}" >&2
      printf 'run %s (no args) for the interactive menu — the user-facing interface.\n' "'glass-atrium'" >&2
      exit 2
      ;;
  esac
}

usage() {
  cat <<'EOF'
glass-atrium — the sole entry point for the Glass Atrium harness.

  glass-atrium                 launch the interactive menu (the only invocation)
  glass-atrium --ascii         launch the menu with ASCII glyphs + mono palette
  glass-atrium -h | --help     show this help

The menu is the whole interface (arrow keys / j,k to move · Enter to select · q to quit):
  Install      deps preflight + install + monitor build + health gate
  Token Setup  provision the headless launchd OAuth token only
  Monitor      open the monitor dashboard in your browser
  Uninstall    remove symlinks + un-wire hooks (--purge via prompt)
  Quit         exit the launcher
EOF
}

# === entrypoint ============================================================
main() {
  local force_ascii=false

  # First pass: peel off our own flags. The menu is the sole user-facing surface, so
  # the only recognized user tokens are -h/--help and --ascii. Any remaining non-flag
  # token routes to the INTERNAL/UNDOCUMENTED passthrough (test/E2E harnesses only).
  if [[ $# -gt 0 ]]; then
    case "$1" in
      -h | --help)
        usage
        exit 0
        ;;
      --ascii)
        force_ascii=true
        shift
        ;;
      *) : ;; # first token => internal passthrough subcommand — handled below
    esac
  fi

  # Any remaining argument => the internal/undocumented passthrough (engine call).
  if [[ $# -gt 0 ]]; then
    passthrough "$@"
    return $?
  fi

  # Interactive mode requires a controlling terminal. Without one (piped/CI),
  # there is no menu to drive — point the user at the passthrough form.
  if [[ ! -t 1 || ! -t 0 ]] || [[ ! -r /dev/tty ]]; then
    printf 'glass-atrium: no interactive terminal available.\n' >&2
    printf 'use the passthrough form, e.g. %s.\n' "'glass-atrium doctor'" >&2
    exit 2
  fi

  # Open the controlling terminal for direct chrome output + key input.
  exec 3<>/dev/tty
  TTY="/dev/fd/3"

  detect_capabilities "${force_ascii}"
  resolve_palette
  resolve_glyphs
  ui_init
  run_menu
  # cleanup (terminal restore + temp sweep) runs via the EXIT trap.
}

# Run main ONLY on direct execution. When sourced (bats unit suite), BASH_SOURCE
